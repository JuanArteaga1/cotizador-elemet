# ============================================
# .gitignore - ELEMENT Cotizador
# Stack: React 19 + Vite + Node.js + Express + Prisma
# ============================================

# ─── Node / npm ──────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── Build outputs ───────────────────────────
dist/
dist-ssr/
build/
out/
.vite/
*.tsbuildinfo

# ─── Environment & secrets ──────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
!.env.example

# ─── Backend ─────────────────────────────────
# SQLite database files
*.db
*.db-journal
*.sqlite
*.sqlite3
prisma/dev.db
prisma/prisma/dev.db

# Prisma generated client (se regenera en cada install)
# Nota: si tu team no regenera Prisma en CI, comenta esta línea
# element-backend/node_modules/.prisma/

# Backend uploads/temp
uploads/
temp/
tmp/

# ─── Docker ──────────────────────────────────
# (NO ignoramos Dockerfile ni docker-compose, se versionan)
# Solo ignorar volúmenes locales de docker
docker-volumes/
*.pid

# ─── IDE / Editors ───────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── OS ─────────────────────────────────────
*.tmp
*.log

# ─── Testing ─────────────────────────────────
coverage/
.nyc_output/
*.test.js.snap

# ─── Misc ────────────────────────────────────
.cache/
.eslintcache
.stylelintcache
.parcel-cache

# ─── Local scripts / debug ───────────────────
scripts/debug-*.js
scripts/test-*.js
scripts/verify-*.js
scripts/inspect-*.js

# ─── Database docs backups ───────────────────
*.sql.bak
*.dump
